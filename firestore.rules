rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: own profile readable by the owner; all readable by admin
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || request.auth.token.role == 'admin');
      allow write: if false;
    }

    // Server-only collections — Cloud Functions (Admin SDK) bypass these rules
    match /user_private/{document} {
      allow read, write: if false;
    }
    match /otp_sessions/{document} {
      allow read, write: if false;
    }
    match /login_challenges/{document} {
      allow read, write: if false;
    }
    match /email_verif_sessions/{document} {
      allow read, write: if false;
    }
    match /rate_limits/{document} {
      allow read, write: if false;
    }
    match /login_challenge_rate/{document} {
      allow read, write: if false;
    }
    match /otp_rate/{document} {
      allow read, write: if false;
    }
    match /email_verif_rate/{document} {
      allow read, write: if false;
    }
    match /config/{document} {
      allow read, write: if false;
    }
  }
}
