rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.uid == 'ilcreatore' || request.auth.token.role == 'admin');
    }

    function isModerator() {
      return signedIn() && request.auth.token.role == 'moderator';
    }

    function isPrivileged() {
      return isAdmin() || isModerator();
    }

    match /users/{userId} {
      allow get: if isSelf(userId) || isPrivileged();
      allow list: if isPrivileged();
      allow create, update, delete: if false;
    }

    match /user_private/{userId} {
      allow read, write: if false;
    }

    match /otp_sessions/{sessionId} {
      allow read, write: if false;
    }

    match /otp_rate/{sessionId} {
      allow read, write: if false;
    }

    match /email_verif_sessions/{sessionId} {
      allow read, write: if false;
    }

    match /email_verif_rate/{sessionId} {
      allow read, write: if false;
    }

    match /login_challenges/{challengeId} {
      allow read, write: if false;
    }

    match /login_challenge_rate/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
